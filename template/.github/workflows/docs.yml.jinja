name: Documentation

on:
  push:
    branches: ["main"]
    tags:
      - "v*"
  pull_request:
    branches: ["main"]

concurrency:
  group: docs-{% raw %}${{ github.ref }}{% endraw %}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  build:
    if: {% raw %}${{ github.event_name == 'pull_request' }}{% endraw %}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Python "3.14"
        uses: actions/setup-python@v5
        with:
          python-version: "3.14"
      - name: Install uv
        uses: astral-sh/setup-uv@v7
        with:
          python-version: "3.14"
          enable-cache: true
      - name: Install dependencies
        run: uv sync --dev
      - name: Build documentation
        run: uv run invoke docs.build
      - name: Upload docs artifact
        uses: actions/upload-artifact@v4
        with:
          name: docs-preview
          path: site/

  deploy:
    if: {% raw %}${{ github.event_name == 'push' }}{% endraw %}
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - name: Set up Python "3.14"
        uses: actions/setup-python@v5
        with:
          python-version: "3.14"
      - name: Install uv
        uses: astral-sh/setup-uv@v7
        with:
          python-version: "3.14"
          enable-cache: true
      - name: Install dependencies
        run: uv sync --dev
      - name: Configure git
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
      - name: Resolve docs version
        id: docs_version
        run: |
          if [[ "${GITHUB_REF_TYPE}" == "tag" ]]; then
            version="${GITHUB_REF_NAME#v}"
            alias="latest"
            set_default="true"
          else
            version="dev"
            alias="dev"
            set_default="true"
          fi
          echo "version=${version}" >> "$GITHUB_OUTPUT"
          echo "alias=${alias}" >> "$GITHUB_OUTPUT"
          echo "set_default=${set_default}" >> "$GITHUB_OUTPUT"
      - name: Deploy versioned docs with mike
        run: |
          uv run invoke docs.deploy-version \
            --version "{% raw %}${{ steps.docs_version.outputs.version }}{% endraw %}" \
            --alias "{% raw %}${{ steps.docs_version.outputs.alias }}{% endraw %}"
      - name: Set default docs version
        if: {% raw %}${{ steps.docs_version.outputs.set_default == 'true' }}{% endraw %}
        run: |
          uv run invoke docs.set-default-version \
            --version "{% raw %}${{ steps.docs_version.outputs.version }}{% endraw %}"

  deploy-package:
    if: {% raw %}${{ startsWith(github.ref, 'refs/tags/v') }}{% endraw %}
    needs: [deploy]
    permissions:
      contents: read
      id-token: write
    uses: ./.github/workflows/publish.yml
    secrets: inherit

  release:
    if: {% raw %}${{ startsWith(github.ref, 'refs/tags/v') }}{% endraw %}
    needs: [deploy-package]
    permissions:
      contents: write
    uses: ./.github/workflows/release.yml
    secrets: inherit
