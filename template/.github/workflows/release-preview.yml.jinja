name: Release Preview

on:
  pull_request:
    branches: ["main"]
    types: [opened, reopened, synchronize, labeled, unlabeled, ready_for_review]

concurrency:
  group: release-preview-{% raw %}${{ github.event.pull_request.number }}{% endraw %}
  cancel-in-progress: true

permissions:
  contents: read
  pull-requests: read

jobs:
  preview:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python "3.13"
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

      - name: Resolve release plan
        id: release_plan
        run: |
          python .github/scripts/release_version.py plan \
            --labels-json '{% raw %}${{ toJson(github.event.pull_request.labels.*.name) }}{% endraw %}' \
            --github-output "$GITHUB_OUTPUT"

      - name: Summarize release preview
        run: |
          {
            echo "## Release Preview"
            echo
            echo "- Current version: {% raw %}${{ steps.release_plan.outputs.current_version }}{% endraw %}"
            echo "- Release bump: {% raw %}${{ steps.release_plan.outputs.bump_type }}{% endraw %}"
            echo "- Next version on merge: v{% raw %}${{ steps.release_plan.outputs.next_version }}{% endraw %}"
            echo
            echo "Supported labels: release:major, release:minor, release:patch"
            echo "Default behavior without a release label: patch"
          } >> "$GITHUB_STEP_SUMMARY"
